{
  "name": "@affex/ai-core",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Multi-provider LLM client with retry, in-memory cache, and optional Langfuse tracing.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@affex/observability-core": "workspace:*",
    "@affex/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^4.77.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@affex/shared-config": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.0",
    "@biomejs/biome": "^1.9.4",
    "openai": "^4.77.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "affex": {
    "layer": "ACTIVE_NOW"
  }
}
