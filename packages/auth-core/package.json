{
  "name": "@affex/auth-core",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Auth.js wrapper for Next.js + JWT verification + argon2 password helpers for any backend.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./password": {
      "types": "./dist/password.d.ts",
      "import": "./dist/password.js",
      "require": "./dist/password.cjs"
    },
    "./jwt": {
      "types": "./dist/jwt.d.ts",
      "import": "./dist/jwt.js",
      "require": "./dist/jwt.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/password.ts src/jwt.ts --format esm,cjs --dts --target node22 --clean",
    "dev": "tsup src/index.ts src/password.ts src/jwt.ts --format esm,cjs --dts --target node22 --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@affex/observability-core": "workspace:*",
    "@affex/shared-types": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "next-auth": "^5.0.0-beta.25"
  },
  "peerDependenciesMeta": {
    "next-auth": { "optional": true }
  },
  "devDependencies": {
    "@affex/shared-config": "workspace:*",
    "@biomejs/biome": "^1.9.4",
    "next-auth": "5.0.0-beta.25",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "affex": {
    "layer": "ACTIVE_NOW"
  }
}
