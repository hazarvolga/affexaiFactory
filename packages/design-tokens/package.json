{
  "name": "@affex/design-tokens",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Design tokens (Tailwind preset + CSS variables) encoding standards/DESIGN.md.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["dist", "src/tokens.css"],
  "scripts": {
    "build": "tsup src/index.ts src/tailwind-preset.ts --format esm,cjs --dts --target node22 --clean",
    "dev": "tsup src/index.ts src/tailwind-preset.ts --format esm,cjs --dts --target node22 --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@affex/shared-config": "workspace:*",
    "@biomejs/biome": "^1.9.4",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "affex": {
    "layer": "ACTIVE_NOW"
  }
}
