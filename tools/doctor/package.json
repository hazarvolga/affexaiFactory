{
  "name": "@affex/doctor",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Repo health checker. Enforces layer boundaries, detects drift, runs dep audit.",
  "type": "module",
  "bin": {
    "doctor": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target node22 --clean",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@affex/shared-config": "workspace:*",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "affex": {
    "layer": "ACTIVE_NOW",
    "role": "tool"
  }
}
